# Alex — Google Cloud (copy to .env and fill in)
# Apply terraform/gcp first, then pull secrets from Console or: gcloud secrets versions access latest --secret=alex-database-url

# --- GCP identity (local dev: path to service account JSON; Cloud Run uses workload identity) ---
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/service-account.json

# --- Vertex AI (Gemini) via LiteLLM — enable VERTEX_MODEL_ID to use GCP; omit to use AWS Bedrock vars ---
VERTEX_MODEL_ID=gemini-2.0-flash-001
# VERTEXAI_PROJECT and VERTEXAI_LOCATION are set automatically from GCP_PROJECT_ID / GCP_REGION when unset

# --- Cloud SQL / Postgres (from Secret Manager secret alex-database-url or terraform output) ---
DATABASE_URL=postgresql://alexadmin:PASSWORD@/alex?host=/cloudsql/PROJECT:REGION:alex-postgres

# --- Planner calling agents on Cloud Run (set after you deploy images) ---
PLANNER_USE_HTTP_AGENTS=true
ALEX_HTTP_TAGGER_URL=https://alex-tagger-xxxxx-uc.a.run.app/invoke
ALEX_HTTP_REPORTER_URL=https://alex-reporter-xxxxx-uc.a.run.app/invoke
ALEX_HTTP_CHARTER_URL=https://alex-charter-xxxxx-uc.a.run.app/invoke
ALEX_HTTP_RETIREMENT_URL=https://alex-retirement-xxxxx-uc.a.run.app/invoke
# Optional: Bearer token if services require authentication
# GCP_AGENT_AUTH_TOKEN=

# --- Storage / vectors (match terraform/gcp bucket name) ---
VECTOR_BUCKET=your-project-id-alex-vectors

# --- Clerk ---
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-instance.clerk.accounts.dev

# --- API keys ---
POLYGON_API_KEY=
OPENAI_API_KEY=
