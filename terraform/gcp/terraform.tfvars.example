project_id = "project-4b1700d0-2b09-4852-8e3"
region     = "us-central1"
app_name   = "alex"

# Optional — sizing
# db_tier         = "db-g1-small"
# db_disk_size_gb = 20

# Optional — GitHub Actions Terraform SA (defaults: create_github_actions_sa = true, create_github_actions_key = true)
# create_github_actions_sa  = false
# create_github_actions_key = false

# =============================================================================
# ENVIRONMENT A — THIS FILE (terraform/gcp/terraform.tfvars)
# You edit these values for: terraform init / plan / apply in terraform/gcp only.
# =============================================================================
#   project_id, region, app_name, optional db_* — no GitHub or Cloud Run UI.

# =============================================================================
# ENVIRONMENT B — GitHub repository (Settings → Secrets and variables → Actions)
# CI/CD and Docker workflow read these — NOT from terraform.tfvars.
# =============================================================================
#   Terraform workflow inputs (Variable or Secret; first match wins):
#     TF_VAR_project_id, GCP_PROJECT_ID, PROJECT_ID, GOOGLE_CLOUD_PROJECT, GCLOUD_PROJECT
#     TF_VAR_region, TF_VAR_REGION, GCP_REGION, GOOGLE_CLOUD_REGION, DEFAULT_REGION, GCLOUD_REGION
#     GCP_SA_KEY, GOOGLE_CREDENTIALS, GCP_CREDENTIALS, GOOGLE_APPLICATION_CREDENTIALS_JSON (SA JSON)
#
#   .github/workflows/docker-gcp.yml (build images, deploy researcher, sync frontend to GCS):
#     ARTIFACT_REGISTRY_URL     ← terraform output artifact_registry_url
#     GCS_FRONTEND_BUCKET       ← terraform output frontend_bucket_name
#     NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY (Secret) — frontend static build
#     NEXT_PUBLIC_API_URL (Variable/Secret) — baked into the static export at build time
#     CLOUD_RUN_RESEARCHER_SERVICE — optional; default alex-researcher
#   CI sets NEXT_PUBLIC_ASSET_PREFIX from the bucket (see frontend/next.config.ts).

# =============================================================================
# ENVIRONMENT C — Cloud Run service: portfolio API (backend/api)  ← dashboard /api/*
# Set in Cloud Run console or gcloud run services update — NOT in terraform.tfvars.
# =============================================================================
#   DATABASE_URL, CLERK_JWKS_URL, CLERK_ISSUER, GCP_PROJECT_ID / Vertex env as needed
#   CORS_ORIGINS / CORS_ORIGIN_REGEX — optional; defaults cover GCS static origins
#   NEXT_PUBLIC_* does not apply here (that is only for the browser build in ENV B).

# =============================================================================
# ENVIRONMENT D — Cloud Run service: researcher (backend/researcher)
# =============================================================================
#   Vertex/Bedrock model env, CORS if you call it from the GCS-hosted site

# =============================================================================
# ENVIRONMENT E — Global HTTP(S) load balancer (terraform/gcp/load_balancer.tf)
# Set in terraform/gcp/terraform.tfvars — routes default traffic to the frontend bucket and /api/* to the portfolio API.
# =============================================================================
#   create_load_balancer       = true
#   cloud_run_api_service_name = "alex-api"   # must already exist in var.region (gcloud run deploy … backend/api)
#   load_balancer_domain       = ""           # optional: e.g. app.example.com — point DNS A/AAAA → terraform output load_balancer_ip first
# After apply: open the site at terraform output load_balancer_http_url (or https URL if domain set), not the raw bucket URL.
# Rebuild the static frontend with NEXT_PUBLIC_API_URL="" (or the LB https URL) so /api/user hits the same host as the UI.
# Researcher stays a separate Cloud Run URL unless you add another path rule later.

# =============================================================================
# Cross-reference (after terraform apply)
# =============================================================================
#   Copy outputs into GitHub Variables where noted above. Re-apply terraform after pulling
#   if the module adds buckets or IAM for the GitHub Actions SA.
# Optional TF overrides: TF_VAR_app_name, TF_VAR_db_tier, TF_VAR_db_disk_size_gb
