project_id = "project-4b1700d0-2b09-4852-8e3"
region     = "us-central1"
app_name   = "alex"

# Optional — sizing
# db_tier         = "db-g1-small"
# db_disk_size_gb = 20

# Optional — GitHub Actions Terraform SA (defaults: create_github_actions_sa = true, create_github_actions_key = true)
# create_github_actions_sa  = false
# create_github_actions_key = false

# --- GitHub Actions: Terraform inputs (repository Variable or Secret; first match wins)
#   Project: TF_VAR_project_id, GCP_PROJECT_ID, PROJECT_ID, GOOGLE_CLOUD_PROJECT, GCLOUD_PROJECT
#   Region:  TF_VAR_region, TF_VAR_REGION, GCP_REGION, GOOGLE_CLOUD_REGION, DEFAULT_REGION, GCLOUD_REGION
#   SA JSON: GCP_SA_KEY, GOOGLE_CREDENTIALS, GCP_CREDENTIALS, GOOGLE_APPLICATION_CREDENTIALS_JSON
# Docker / Cloud Run / frontend (.github/workflows/docker-gcp.yml):
#   ARTIFACT_REGISTRY_URL = terraform output artifact_registry_url
#   GCS_FRONTEND_BUCKET   = terraform output frontend_bucket_name (static Next export → GCS)
#   NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY (secret) — required for frontend build unless you skip static deploy
#   NEXT_PUBLIC_API_URL — optional; point at your Cloud Run / API URL for the demo
#   CLOUD_RUN_RESEARCHER_SERVICE — defaults to alex-researcher if app_name is alex
# Re-apply terraform after pulling: adds GCS frontend bucket + roles/run.admin on the GitHub Actions SA
# Optional overrides:
#   TF_VAR_app_name        = alex
#   TF_VAR_db_tier         = db-f1-micro
#   TF_VAR_db_disk_size_gb = 10
# Repository Secret: GCP_SA_KEY = full JSON from terraform output github_actions_sa_key_base64 (decoded) or gcloud key create
# After apply, optionally copy terraform outputs into Variables: artifact_registry_url, gcs_vectors_bucket, etc.
